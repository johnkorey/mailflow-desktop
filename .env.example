# MailFlow Environment Configuration — copy to .env and fill in real values

# Server port
PORT=3000

# JWT secret for auth tokens — generate a long random string
JWT_SECRET=change-me-to-a-long-random-string

# AI features (optional) — get a free Groq API key at https://console.groq.com
# GROQ_API_KEY=your-groq-api-key

# Encryption key for stored SMTP passwords (optional — auto-generated on first launch if not set)
# Must be at least 32 characters
# ENCRYPTION_KEY=your-32-character-encryption-key

# Base URL used in unsubscribe links sent to recipients
# UNSUBSCRIBE_BASE_URL=https://your-domain.com
