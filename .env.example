# MailFlow Environment Configuration — copy to .env and fill in real values.
#
# SECURITY NOTE: .env is gitignored. Never commit real secrets here.
# Generate strong random values with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Server port
PORT=3000

# Encryption key for stored SMTP passwords AND unsubscribe-link HMAC secret.
# If left unset, the app auto-generates one per install and persists it in
# the user-data dir. Override here only when you need deterministic keys
# across machines (e.g. restoring a backup onto a second device).
# Must be at least 32 characters of high-entropy randomness.
# ENCRYPTION_KEY=

# Base URL used in the unsubscribe links embedded in outgoing emails.
# Must be a public HTTPS URL reachable by recipients — DO NOT leave this
# as localhost in production or clicking "unsubscribe" will 404.
# UNSUBSCRIBE_BASE_URL=https://your-domain.com

# Log verbosity for the Electron main process. Written to
# %APPDATA%\MailFlow 2.0\logs\main.log (Windows). One of:
# error, warn, info (default), debug.
# MAILFLOW_LOG_LEVEL=info
