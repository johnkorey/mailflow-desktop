{
  "name": "mailflow-marketing",
  "version": "1.0.0",
  "description": "Marketing video generator for MailFlow Desktop — Remotion-based.",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render MailFlowMarketing output/MailFlow-Marketing-v1.mp4 --codec=h264 --crf=18",
    "preview": "remotion render MailFlowMarketing output/preview.mp4 --frames=0-149 --codec=h264 --crf=22"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "msedge-tts": "^2.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.4.0"
  }
}
