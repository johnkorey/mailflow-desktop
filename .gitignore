# ===== Secrets & user data — NEVER commit =====
.env
.env.*
!.env.example
encryption.key
license.json
*.pem
*.key
*.crt

# Local SQLite database (per-install user data)
database/emailsaas.db
database/emailsaas.db-journal
database/emailsaas.db-wal
database/emailsaas.db-shm

# User-uploaded files (per-install runtime data, not source)
public/uploads/templates/*
!public/uploads/templates/.gitkeep

# ===== Build output =====
dist/
build/output/
out/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.blockmap
latest.yml
latest-mac.yml
latest-linux.yml

# ===== Dependencies =====
node_modules/
.pnp/
.pnp.js

# ===== Editor / IDE =====
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ===== Logs =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===== Testing / coverage =====
coverage/
.nyc_output/
*.lcov

# ===== Misc local state =====
.cache/
.temp/
.tmp/
*.tmp

# ===== Claude Code workspace state (private to this dev machine) =====
.claude/

# ===== Marketing video build output (Remotion) =====
# Keep source .tsx/.ts/.md files committed; skip node_modules + rendered video
marketing/node_modules/
marketing/output/*.mp4
marketing/.remotion-cache/
